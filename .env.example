# Backend AI provider: gemini | gemma | offline
AI_PROVIDER=gemma

# Gemini cloud mode accepts either variable name.
API_Key=
GOOGLE_API_KEY=

# Local Gemma via Ollama-compatible endpoint.
GEMMA_ENDPOINT=http://127.0.0.1:11434/api/generate
GEMMA_MODEL=gemma3:4b

AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-for-production
DEMO_MODE=false
VITE_API_BASE_URL=http://127.0.0.1:8000
